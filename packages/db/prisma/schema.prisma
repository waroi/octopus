datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0)

  bannedAt     DateTime?
  bannedReason String?

  sessions Session[]
  accounts Account[]
  organizationMembers OrganizationMember[]
  sentInvitations     OrganizationInvitation[]
  chatConversations   ChatConversation[]
  favoriteRepositories FavoriteRepository[]
  removedMembers      OrganizationMember[] @relation("RemovedByUser")
  deletedKnowledgeDocs  KnowledgeDocument[] @relation("DeletedKnowledgeDocs")
  knowledgeAuditLogs    KnowledgeAuditLog[]
  createdApiTokens      OrgApiToken[] @relation("CreatedApiTokens")
  packageAnalyses       PackageAnalysis[]
  safePackageRequests   SafePackageRequest[]
  packageDeepDives      PackageDeepDive[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verifications")
}

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  avatarUrl            String?
  githubInstallationId Int?     @unique
  needsPermissionGrant Boolean  @default(false)
  openaiApiKey         String?
  anthropicApiKey      String?
  cohereApiKey         String?
  googleApiKey         String?
  defaultModelId       String?
  defaultEmbedModelId  String?
  monthlySpendLimitUsd    Float?   @default(150)
  checkFailureThreshold   String   @default("critical") // "critical" | "high" | "medium" | "none"
  reviewsPaused           Boolean  @default(false)
  blockedAuthors          Json     @default("[]") // string[] of PR author usernames to skip review
  defaultReviewConfig     Json     @default("{}")
  stripeCustomerId        String?  @unique
  creditBalance           Decimal  @default(0) @db.Decimal(12, 4)
  freeCreditBalance       Decimal  @default(150) @db.Decimal(12, 4)
  billingEmail            String?
  githubMarketplacePlanId   Int?
  githubMarketplacePlanName String?
  githubMarketplaceAccountId Int?     @unique
  githubMarketplaceOnFreeTrial Boolean @default(false)
  githubMarketplaceFreeTrialEndsOn DateTime?
  type                 Int      @default(1) // 1=standard, 2=community, 3=friendly
  communityDailyReviewLimit Int  @default(5)
  typeChanges          OrgTypeChange[]
  bannedAt             DateTime?
  bannedReason         String?
  deletedAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members            OrganizationMember[]
  invitations        OrganizationInvitation[]
  repositories       Repository[]
  knowledgeDocuments KnowledgeDocument[]
  chatConversations  ChatConversation[]
  slackIntegration      SlackIntegration?
  collabIntegration     CollabIntegration?
  bitbucketIntegration  BitbucketIntegration?
  linearIntegration     LinearIntegration?
  aiUsages           AiUsage[]
  knowledgeAuditLogs KnowledgeAuditLog[]
  daySummaries       DaySummary[]
  creditTransactions CreditTransaction[]
  autoReloadConfig   AutoReloadConfig?
  apiTokens          OrgApiToken[]
  localAgents        LocalAgent[]
  agentSearchTasks   AgentSearchTask[]
  packageAnalyses       PackageAnalysis[]
  safePackageRequests   SafePackageRequest[]
  packageDeepDives      PackageDeepDive[]

  @@map("organizations")
}

model OrganizationMember {
  id        String    @id @default(cuid())
  role      String    @default("member")
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  removedById String?
  removedBy   User?  @relation("RemovedByUser", fields: [removedById], references: [id], onDelete: SetNull)

  emailNotificationPreferences EmailNotificationPreference[]

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model OrganizationInvitation {
  id        String   @id @default(cuid())
  email     String
  role      String   @default("member") // admin | member
  token     String   @unique @default(cuid())
  status    String   @default("pending") // pending | accepted | expired | revoked
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invitedById String
  invitedBy   User @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([token])
  @@map("organization_invitations")
}

model Repository {
  id            String   @id @default(cuid())
  name          String
  fullName      String
  provider      String   @default("github")
  externalId    String
  defaultBranch String   @default("main")
  isActive      Boolean  @default(true)
  autoReview    Boolean  @default(false)
  installationId Int?
  indexStatus    String   @default("pending") // pending | indexing | indexed | failed
  indexedAt      DateTime?
  indexedFiles   Int      @default(0)
  totalFiles     Int      @default(0)
  totalChunks    Int      @default(0)
  totalVectors   Int      @default(0)
  indexDurationMs    Int?
  contributorCount   Int      @default(0)
  contributors       Json     @default("[]")
  summary        String?
  purpose        String?
  analysis       String?
  analysisStatus String    @default("none")
  analyzedAt     DateTime?
  reviewModelId  String?
  embedModelId   String?
  reviewConfig   Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  pullRequests          PullRequest[]
  collabProjectMappings CollabProjectMapping[]
  favoritedBy           FavoriteRepository[]
  linearTeamMappings    LinearTeamMapping[]
  packageAnalyses       PackageAnalysis[]

  @@unique([provider, externalId])
  @@index([organizationId, isActive])
  @@index([organizationId, name])
  @@map("repositories")
}

model PullRequest {
  id                 String    @id @default(cuid())
  number             Int
  title              String
  url                String
  author             String
  status             String    @default("pending") // pending | reviewing | completed | failed
  triggerCommentId   BigInt
  triggerCommentBody String
  headSha            String?
  reviewCommentId    BigInt?
  reviewBody         String?
  errorMessage       String?
  mergedAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  reviewIssues ReviewIssue[]

  @@unique([repositoryId, number])
  @@index([repositoryId, status])
  @@map("pull_requests")
}

model ReviewIssue {
  id             String    @id @default(cuid())
  title          String
  description    String
  severity       String    @default("medium") // critical | high | medium | low
  confidence     String?   // "HIGH" | "MEDIUM" | "LOW"
  filePath       String?
  lineNumber     Int?
  acknowledgedAt DateTime?
  feedback       String?   // "up" | "down" | null
  feedbackAt     DateTime?
  feedbackBy     String?
  createdAt      DateTime  @default(now())

  linearIssueId  String?
  linearIssueUrl String?
  githubIssueNumber Int?
  githubIssueUrl    String?
  githubCommentId   BigInt?

  pullRequestId String
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)

  @@index([pullRequestId])
  @@map("review_issues")
}

model KnowledgeDocument {
  id             String   @id @default(cuid())
  title          String
  content        String
  sourceType     String   @default("paste") // "paste" | "file"
  fileName       String?
  status         String   @default("processing") // "processing" | "ready" | "error"
  errorMessage   String?
  totalChunks    Int      @default(0)
  totalVectors   Int      @default(0)
  processingMs   Int?
  deletedAt      DateTime?
  deletedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deletedBy      User?    @relation("DeletedKnowledgeDocs", fields: [deletedById], references: [id])
  auditLogs      KnowledgeAuditLog[]

  @@index([organizationId, status, deletedAt])
  @@map("knowledge_documents")
}

model KnowledgeAuditLog {
  id         String   @id @default(cuid())
  action     String   // "created" | "updated" | "deleted" | "restored"
  details    String?
  createdAt  DateTime @default(now())

  documentId     String
  document       KnowledgeDocument @relation(fields: [documentId], references: [id])
  userId         String
  user           User @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([documentId])
  @@index([organizationId, createdAt])
  @@map("knowledge_audit_logs")
}

model ChatConversation {
  id        String    @id @default(cuid())
  title     String    @default("New Chat")
  isShared  Boolean   @default(false)
  sharedAt  DateTime?
  sharedById String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  messages ChatMessage[]
  chatQueue ChatQueue[]

  @@index([userId, organizationId])
  @@index([organizationId, isShared])
  @@map("chat_conversations")
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user" | "assistant"
  content   String
  userId    String?  // sender (null = assistant or legacy messages)
  userName  String?  // denormalized name
  createdAt DateTime @default(now())

  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chat_messages")
}

model ChatQueue {
  id             String    @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  userName       String
  content        String
  status         String    @default("waiting") // waiting | processing | completed | failed
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  @@index([conversationId, status])
  @@map("chat_queue")
}

model EmailNotificationPreference {
  id        String  @id @default(cuid())
  eventType String
  enabled   Boolean @default(false)

  memberId String
  member   OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, eventType])
  @@index([memberId])
  @@map("email_notification_preferences")
}

model SlackIntegration {
  id          String  @id @default(cuid())
  teamId      String
  teamName    String
  accessToken String
  botUserId   String?
  channelId   String?
  channelName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  eventConfigs SlackEventConfig[]

  @@map("slack_integrations")
}

model SlackEventConfig {
  id        String  @id @default(cuid())
  eventType String
  enabled   Boolean @default(true)

  slackIntegrationId String
  slackIntegration   SlackIntegration @relation(fields: [slackIntegrationId], references: [id], onDelete: Cascade)

  @@unique([slackIntegrationId, eventType])
  @@map("slack_event_configs")
}

model BitbucketIntegration {
  id             String   @id @default(cuid())
  workspaceSlug  String
  workspaceName  String
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  scopes         String?
  webhookUuid    String?
  webhookSecret  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("bitbucket_integrations")
}

model CollabIntegration {
  id              String  @id @default(cuid())
  apiKey          String
  baseUrl         String
  workspaceId     String?
  workspaceName   String?
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projectMappings CollabProjectMapping[]

  @@map("collab_integrations")
}

model AiUsage {
  id             String   @id @default(cuid())
  provider       String   // "anthropic" | "openai" | "google"
  model          String   // "claude-sonnet-4-20250514", "gemini-2.5-pro", etc.
  operation      String   // "review" | "summarize-repo" | "summarize-daily" | "analyze" | "chat" | "chat-title" | "embedding"
  inputTokens      Int
  outputTokens     Int
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  usedOwnKey       Boolean  @default(false)
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([createdAt])
  @@index([usedOwnKey, createdAt])
  @@map("ai_usages")
}

model CollabProjectMapping {
  id                String @id @default(cuid())
  collabProjectId   String
  collabProjectName String

  repositoryId       String
  repository         Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  collabIntegrationId String
  collabIntegration   CollabIntegration @relation(fields: [collabIntegrationId], references: [id], onDelete: Cascade)

  @@unique([collabIntegrationId, repositoryId])
  @@map("collab_project_mappings")
}

model LinearIntegration {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accessToken    String
  workspaceId    String
  workspaceName  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teamMappings   LinearTeamMapping[]

  @@map("linear_integrations")
}

model LinearTeamMapping {
  id                  String   @id @default(cuid())
  linearTeamId        String
  linearTeamName      String
  linearTeamKey       String
  repositoryId        String
  repository          Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  linearIntegrationId String
  linearIntegration   LinearIntegration @relation(fields: [linearIntegrationId], references: [id], onDelete: Cascade)

  @@unique([linearIntegrationId, repositoryId])
  @@map("linear_team_mappings")
}

model FavoriteRepository {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([userId, repositoryId])
  @@index([userId])
  @@map("favorite_repositories")
}

model DaySummary {
  id        String   @id @default(cuid())
  date      String   // "2026-02-25"
  summary   String   @db.Text
  prCount   Int      // number of PRs included in the summary
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date])
  @@index([organizationId, date])
  @@map("day_summaries")
}

model CreditTransaction {
  id                    String   @id @default(cuid())
  amount                Decimal  @db.Decimal(12, 4)
  type                  String   // "purchase" | "usage" | "free_credit" | "refund" | "auto_reload"
  description           String?
  stripeSessionId       String?  @unique
  receiptUrl            String?
  balanceAfter          Decimal  @db.Decimal(12, 4)
  createdAt             DateTime @default(now())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("credit_transactions")
}

model AutoReloadConfig {
  id              String   @id @default(cuid())
  enabled         Boolean  @default(false)
  thresholdAmount Decimal  @db.Decimal(12, 4) @default(10)
  reloadAmount    Decimal  @db.Decimal(12, 4) @default(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  organizationId  String   @unique
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("auto_reload_configs")
}

model OrgApiToken {
  id             String    @id @default(cuid())
  name           String
  tokenHash      String    @unique
  tokenPrefix    String    // "oct_abc1..." (first 8 chars for display)
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User @relation("CreatedApiTokens", fields: [createdById], references: [id], onDelete: Cascade)

  localAgents    LocalAgent[]

  @@index([tokenHash])
  @@map("org_api_tokens")
}

model CliAuthSession {
  id         String   @id @default(cuid())
  deviceCode String   @unique
  status     String   @default("pending") // pending | approved | expired
  token      String?  // raw token, cleared after CLI polls it
  orgId      String?
  orgSlug    String?
  orgName    String?
  userName   String?
  userEmail  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([deviceCode])
  @@map("cli_auth_sessions")
}

model AvailableModel {
  id          String   @id @default(cuid())
  modelId     String   @unique
  displayName String
  provider    String   // "anthropic" | "openai" | "google"
  category    String   // "llm" | "embedding"
  inputPrice  Float    // per 1M tokens, USD
  outputPrice Float    // per 1M tokens, USD
  isActive           Boolean  @default(true)
  isPlatformDefault  Boolean  @default(false)
  sortOrder          Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("available_models")
}

model SystemConfig {
  id        String   @id @default("singleton")
  defaultReviewConfig Json @default("{}")
  blockedAuthors      Json @default("[]") // string[] of globally blocked PR author usernames
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  unsubscribedAt DateTime?

  @@map("newsletter_subscribers")
}

model PackageAnalysis {
  id             String   @id @default(cuid())
  repoUrl        String   // GitHub URL (for ad-hoc analyses)
  repoName       String   // "owner/repo"
  commitHash     String?  // HEAD commit at time of analysis (for cache)
  status         String   @default("running") // "running" | "completed" | "failed"
  results        Json?    // DependencyRiskReport[]
  analyzedFiles  Json?    // string[] — which package.json files were analyzed
  totalPackages  Int      @default(0)
  criticalCount  Int      @default(0)
  highCount      Int      @default(0)
  mediumCount    Int      @default(0)
  durationMs     Int?
  errorMessage   String?
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  repositoryId   String?
  repository     Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deepDives PackageDeepDive[]

  @@index([organizationId, createdAt])
  @@index([repositoryId, commitHash])
  @@map("package_analyses")
}

/// Global safe packages list — admin-approved, checked before every scan
model SafePackage {
  id              String   @id @default(cuid())
  name            String   @unique // npm package name
  weeklyDownloads Int      @default(0)
  reason          String?  // why it's considered safe
  approvedBy      String?  // admin user id
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("safe_packages")
}

/// User requests to mark a package as safe — goes to admin for approval
model SafePackageRequest {
  id        String   @id @default(cuid())
  name      String   // npm package name
  version   String?
  reason    String   // user's justification
  status    String   @default("pending") // "pending" | "approved" | "rejected"
  reviewedBy String? // admin who reviewed
  reviewNote String? // admin's note on decision
  createdAt DateTime @default(now())
  reviewedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([organizationId])
  @@map("safe_package_requests")
}

model PackageDeepDive {
  id            String   @id @default(cuid())
  packageName   String
  version       String?
  verdict       String   // "malicious" | "suspicious" | "likely_safe" | "safe"
  confidence    String   // "high" | "medium" | "low"
  summary       String
  findings      Json     // DeepDiveFinding[]
  recommendation String
  filesAnalyzed Int      @default(0)
  totalSize     Int      @default(0)
  model         String?  // AI model used
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  createdAt     DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  analysisId String?
  analysis   PackageAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)

  @@index([packageName, version])
  @@index([organizationId, createdAt])
  @@index([analysisId])
  @@map("package_deep_dives")
}

model BlogPost {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String    @db.Text
  coverImageUrl String?
  status        String    @default("draft") // "draft" | "published"
  publishedAt   DateTime?
  authorId      String
  authorName    String
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, publishedAt])
  @@map("blog_posts")
}

model BlogApiToken {
  id          String    @id @default(cuid())
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  lastUsedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([tokenHash])
  @@map("blog_api_tokens")
}

model LocalAgent {
  id             String    @id @default(cuid())
  name           String    // e.g. "gabo-macbook"
  status         String    @default("offline") // "online" | "offline"
  lastSeenAt     DateTime?
  repoFullNames  Json      @default("[]") // string[] of repo fullNames this agent has locally
  capabilities   Json      @default("[]") // string[] e.g. ["ripgrep", "claude-cli"]
  machineInfo    Json?     // { os, hostname, nodeVersion }
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  apiTokenId     String
  apiToken       OrgApiToken @relation(fields: [apiTokenId], references: [id], onDelete: Cascade)

  agentSearchTasks AgentSearchTask[]

  @@unique([organizationId, name])
  @@index([organizationId, status])
  @@map("local_agents")
}

model AgentSearchTask {
  id             String    @id @default(cuid())
  query          String
  searchType     String    @default("semantic") // "grep" | "file-read" | "semantic" | "claude"
  params         Json      @default("{}")
  status         String    @default("pending") // "pending" | "claimed" | "completed" | "timeout" | "failed"
  result         Json?
  resultSummary  String?   @db.Text
  errorMessage   String?
  timeoutMs      Int       @default(10000)
  claimedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  agentId        String?
  agent          LocalAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  repoFullName   String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  conversationId String?

  @@index([organizationId, status])
  @@index([agentId, status])
  @@index([repoFullName, status])
  @@map("agent_search_tasks")
}

model AskOctopusSession {
  id            String   @id @default(cuid())
  fingerprint   String
  ipAddress     String
  userAgent     String?
  country       String?
  flagged       Boolean  @default(false)
  flagReason    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages AskOctopusMessage[]

  @@index([fingerprint])
  @@index([ipAddress])
  @@index([flagged])
  @@index([createdAt])
  @@map("ask_octopus_sessions")
}

model AskOctopusMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  session AskOctopusSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("ask_octopus_messages")
}

// ── Status Page ─────────────────────────────────────────────────────────────

model StatusComponent {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "System", "RAG", "Chat", "Reviews", "Webhooks"
  description String?
  status      String   @default("operational") // "operational" | "degraded" | "partial_outage" | "major_outage" | "maintenance"
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  incidents StatusIncident[]

  @@index([sortOrder])
  @@map("status_components")
}

model StatusIncident {
  id            String    @id @default(cuid())
  title         String
  severity      String    // "critical" | "major" | "minor" | "maintenance"
  status        String    @default("investigating") // "investigating" | "identified" | "monitoring" | "resolved"
  message       String    @db.Text
  componentId   String?
  resolvedAt    DateTime?
  createdById   String?
  createdByName String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  component StatusComponent? @relation(fields: [componentId], references: [id], onDelete: SetNull)
  updates   StatusIncidentUpdate[]

  @@index([status, createdAt])
  @@index([componentId])
  @@map("status_incidents")
}

model StatusIncidentUpdate {
  id            String   @id @default(cuid())
  status        String   // same as incident status options
  message       String   @db.Text
  createdById   String?
  createdByName String?
  createdAt     DateTime @default(now())

  incidentId String
  incident   StatusIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("status_incident_updates")
}

model StatusApiToken {
  id          String    @id @default(cuid())
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  lastUsedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([tokenHash])
  @@map("status_api_tokens")
}

model AuditLog {
  id             String   @id @default(cuid())
  action         String   // e.g. "user.login", "email.sent", "review.completed"
  category       String   // "auth" | "email" | "review" | "repo" | "knowledge" | "billing" | "admin" | "system"
  actorId        String?  // userId who triggered the action (null for system events)
  actorEmail     String?  // denormalized for quick display
  targetType     String?  // e.g. "user", "organization", "repository", "pr"
  targetId       String?  // ID of the target entity
  organizationId String?  // org scope (null for platform-level events)
  metadata       Json     @default("{}") // extra context (prNumber, repoName, recipient, etc.)
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([category, createdAt])
  @@index([actorId, createdAt])
  @@index([organizationId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Organization Type History ────────────────────────────────────────────────

model OrgTypeChange {
  id             String   @id @default(cuid())
  fromType       Int      // previous type (1=standard, 2=community, 3=friendly)
  toType         Int      // new type
  reason         String?  // optional note
  changedById    String?  // admin user who made the change (null for system changes)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@map("org_type_changes")
}
