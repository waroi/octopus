# Database
DATABASE_URL=postgresql://octopus:octopus@localhost:43332/octopus

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Octopus

# Redis
REDIS_URL=

# Qdrant (Vector DB)
QDRANT_URL=http://localhost:43333

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
NEXT_PUBLIC_GITHUB_APP_SLUG=

# Bitbucket OAuth
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
BITBUCKET_REDIRECT_URI=http://localhost:3000/api/bitbucket/callback

# Pubby (Real-time)
PUBBY_APP_ID=
PUBBY_APP_KEY=
PUBBY_APP_SECRET=
NEXT_PUBLIC_PUBBY_KEY=

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=octopus

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Linear OAuth
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=http://localhost:3000/api/linear/callback

# Slack Integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/slack/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cohere (Reranking)
COHERE_API_KEY=

# Resend (Transactional Emails)
RESEND_API_KEY=

# Email sender defaults (used when seeding templates)
EMAIL_PERSONAL_FROM_NAME=
EMAIL_PERSONAL_FROM_EMAIL=
EMAIL_SYSTEM_FROM_NAME=Octopus
EMAIL_SYSTEM_FROM_EMAIL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=

# Review worker
# Only containers with this set to "true" will consume pg-boss "process-review"
# jobs. In production, set this on review-engine replicas only. For local dev
# (single process), set to "true".
ENABLE_REVIEW_WORKERS=true

# Cloudflare R2 (org avatars, file uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=octopus
R2_PUBLIC_URL=

# Ollama (optional, self-hosted LLM provider)
OLLAMA_SERVER_URL=
OLLAMA_USERNAME=
OLLAMA_PASSWORD=
